{
  "name": "astro-portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "build": "astro check && astro build && bun run build:tailwind && bun run build:postcss",
    "build:postcss": "postcss dist/global.css -o dist/global.css",
    "build:tailwind": "bun x @tailwindcss/cli -i src/styles/global.css -o dist/global.css --minify",
    "decap": "bun x decap-server",
    "dev": "astro dev",
    "format": "prettier --write .",
    "preview": "astro preview"
  },
  "dependencies": {
    "@ai-sdk/groq": "^4.0.1",
    "@astrojs/netlify": "^8.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@felixicaza/astro-capo": "^1.2.1",
    "@lexingtonthemes/seo": "^0.4.0",
    "ai": "^7.0.4",
    "astro": "^7.0.3",
    "astro-expressive-code": "^0.44.0",
    "astro-icon": "^1.1.5",
    "astro-og-canvas": "^0.12.0",
    "clsx": "^2.1.1",
    "marked": "^18.0.5",
    "remend": "^1.3.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@iconify-json/bxl": "^1.2.4",
    "@iconify-json/iconoir": "^1.2.11",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.87",
    "@iconify-json/tabler": "^1.2.35",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.9.0",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
