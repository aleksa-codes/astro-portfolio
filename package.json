{
  "name": "astro-start",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "build": "astro check && astro build && bun run build:tailwind && bun run build:postcss",
    "build:postcss": "postcss dist/global.css -o dist/global.css",
    "build:tailwind": "bun x @tailwindcss/cli -i src/styles/global.css -o dist/global.css --minify",
    "decap": "bun x decap-server",
    "dev": "astro dev",
    "format": "prettier --write .",
    "preview": "astro preview"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.29",
    "@astrojs/check": "^0.9.7",
    "@astrojs/netlify": "^7.0.1",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@felixicaza/astro-capo": "^1.0.1",
    "@northsoon/astro-seo": "^1.0.2",
    "@playform/compress": "^0.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "ai": "^6.0.116",
    "astro": "^6.0.2",
    "astro-expressive-code": "^0.41.7",
    "astro-icon": "^1.1.5",
    "astro-og-canvas": "^0.10.1",
    "clsx": "^2.1.1",
    "marked": "^17.0.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/bxl": "^1.2.4",
    "@iconify-json/iconoir": "^1.2.10",
    "@iconify-json/lucide": "^1.2.96",
    "@iconify-json/simple-icons": "^1.2.73",
    "@iconify-json/tabler": "^1.2.31",
    "@tailwindcss/typography": "^0.5.19",
    "postcss-cli": "^11.0.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
