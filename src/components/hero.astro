---
import Avatar from "@/components/avatar.astro"
---

<section id="home" class="flex flex-col items-start">
  <div class="mb-14">
    <Avatar statusText="Open to work" class="h-24 w-24 md:h-32 md:w-32" />
  </div>

  <h1
    class="mb-6 text-4xl leading-[1.1] font-bold tracking-tighter text-foreground sm:text-5xl md:text-6xl"
  >
    I design and build <br />
    <span
      class="bg-linear-to-r from-foreground to-muted-foreground bg-clip-text text-transparent"
      >things for the web.</span
    >
  </h1>

  <p
    class="max-w-2xl text-base leading-relaxed text-muted-foreground md:text-lg"
  >
    Hey there <span class="inline-block origin-bottom-right animate-wave"
      >👋</span
    > I'm Aleksa. I build fast, good-looking websites and apps that actually hold
    up when real people use them.
  </p>
</section>
