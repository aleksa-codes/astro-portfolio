---
interface Props {
  username?: string;
}

const { username = 'aleksa-codes' }: Props = Astro.props;

let totalStars = 0;
let followers = 0;
let publicRepos = 0;
let fetchError = false;

try {
  const [userRes, reposRes] = await Promise.all([
    fetch(`https://api.github.com/users/${username}`),
    fetch(`https://api.github.com/users/${username}/repos?per_page=100`),
  ]);

  if (!userRes.ok || !reposRes.ok) throw new Error('API Error');

  const userData = await userRes.json();
  const reposData = await reposRes.json();

  followers = userData.followers;
  publicRepos = userData.public_repos;
  totalStars = reposData.reduce((acc: number, repo: any) => acc + repo.stargazers_count, 0);
} catch (e) {
  console.error('Stats fetch error:', e);
  fetchError = true;
}

const boxClass =
  'p-3 sm:p-4 bg-secondary/30 rounded-xl border border-border flex flex-col items-center justify-center gap-2 transition-colors hover:bg-secondary/50 min-h-[84px]';
const iconClass = 'h-4 w-4 text-muted-foreground/70';
---

<div
  class='border-border bg-secondary/30 flex w-full flex-1 items-center justify-center rounded-xl border p-4'
>
  <div class='flex w-fit flex-col gap-2'>
    <div id='gh-labels' class='flex gap-0.75'>
      <!-- Skeleton label placeholders to reserve height -->
      {
        Array.from({ length: 17 }).map(() => (
          <span class='w-2.75 shrink-0 text-xs font-medium md:w-3'>&nbsp;</span>
        ))
      }
    </div>
    <div id='gh-graph' data-username={username} class='flex gap-0.75'>
      <!-- Skeleton loading state -->
      {
        Array.from({ length: 17 }).map(() => (
          <div class='flex flex-col gap-0.75'>
            {Array.from({ length: 7 }).map(() => (
              <div class='bg-secondary/60 h-2.75 w-2.75 animate-pulse rounded-[2px] md:h-3 md:w-3' />
            ))}
          </div>
        ))
      }
    </div>
    <p id='gh-graph-error' class='text-muted-foreground/60 hidden text-center text-xs'>
      Could not load contribution data
    </p>
  </div>
</div>

<div class='mt-auto grid grid-cols-3 gap-3'>
  {
    fetchError ? (
      <div class='col-span-3 p-3 text-center text-sm text-red-500/80'>Failed to load stats.</div>
    ) : (
      <>
        <div class={boxClass}>
          <div class='flex items-center gap-1.5'>
            <svg
              class={iconClass}
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.5'
              stroke-linecap='round'
              stroke-linejoin='round'
            >
              <polygon points='12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2' />
            </svg>
            <div class='text-foreground text-xl leading-none font-bold'>{totalStars}</div>
          </div>
          <div class='text-muted-foreground text-[11px] font-semibold tracking-widest uppercase'>
            Stars
          </div>
        </div>
        <div class={boxClass}>
          <div class='flex items-center gap-1.5'>
            <svg
              class={iconClass}
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.5'
              stroke-linecap='round'
              stroke-linejoin='round'
            >
              <path d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2' />
              <circle cx='9' cy='7' r='4' />
              <path d='M22 21v-2a4 4 0 0 0-3-3.87' />
              <path d='M16 3.13a4 4 0 0 1 0 7.75' />
            </svg>
            <div class='text-foreground text-xl leading-none font-bold'>{followers}</div>
          </div>
          <div class='text-muted-foreground text-[11px] font-semibold tracking-widest uppercase'>
            Followers
          </div>
        </div>
        <div class={boxClass}>
          <div class='flex items-center gap-1.5'>
            <svg
              class={iconClass}
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.5'
              stroke-linecap='round'
              stroke-linejoin='round'
            >
              <path d='M4 19.5A2.5 2.5 0 0 1 6.5 17H20' />
              <path d='M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z' />
            </svg>
            <div class='text-foreground text-xl leading-none font-bold'>{publicRepos}</div>
          </div>
          <div class='text-muted-foreground text-[11px] font-semibold tracking-widest uppercase'>
            Repos
          </div>
        </div>
      </>
    )
  }
</div>

<script>
  const username =
    document.getElementById('gh-graph')?.getAttribute('data-username') || 'aleksa-codes';

  type Contribution = {
    date: string;
    count: number;
  };

  async function fetchContributions() {
    try {
      const response = await fetch(
        `https://github-contributions-api.jogruber.de/v4/${username}?y=last`,
      );
      if (!response.ok) throw new Error('Failed to fetch');
      const data = await response.json();
      return data.contributions;
    } catch (e) {
      console.error('Error fetching contributions:', e);
      return null;
    }
  }

  async function renderGraph() {
    const graphContainer = document.getElementById('gh-graph');
    const labelsContainer = document.getElementById('gh-labels');
    if (!graphContainer || !labelsContainer) return;

    const contributions: Contribution[] = await fetchContributions();

    graphContainer.innerHTML = '';
    labelsContainer.innerHTML = '';

    const errorEl = document.getElementById('gh-graph-error');
    if (!contributions && errorEl) {
      errorEl.classList.remove('hidden');
    } else if (errorEl) {
      errorEl.classList.add('hidden');
    }

    const colors = [
      'bg-[var(--gh-0)]',
      'bg-[var(--gh-1)]',
      'bg-[var(--gh-2)]',
      'bg-[var(--gh-3)]',
      'bg-[var(--gh-4)]',
    ];

    const cols = 17;
    const rows = 7;

    const today = new Date();
    const startDate = new Date(today);
    startDate.setDate(today.getDate() - today.getDay());
    startDate.setDate(startDate.getDate() - (cols - 1) * 7);

    const monthNames = [
      'Jan',
      'Feb',
      'Mar',
      'Apr',
      'May',
      'Jun',
      'Jul',
      'Aug',
      'Sep',
      'Oct',
      'Nov',
      'Dec',
    ];
    const monthLabels = [];
    let lastMonth = -1;

    for (let i = 0; i < cols; i++) {
      const colDiv = document.createElement('div');
      colDiv.className = 'flex flex-col gap-[3px]';

      const colDate = new Date(startDate);
      colDate.setDate(startDate.getDate() + i * 7);

      if (colDate.getMonth() !== lastMonth) {
        monthLabels.push({ name: monthNames[colDate.getMonth()], index: i });
        lastMonth = colDate.getMonth();
      }

      for (let j = 0; j < rows; j++) {
        const cellDate = new Date(colDate);
        cellDate.setDate(colDate.getDate() + j);
        const dateStr = cellDate.toISOString().split('T')[0];

        let intensity = 0;
        let count = 0;

        if (contributions) {
          const dayData = contributions.find(c => c.date === dateStr);
          if (dayData) {
            count = dayData.count;
            if (count === 0) intensity = 0;
            else if (count <= 2) intensity = 1;
            else if (count <= 5) intensity = 2;
            else if (count <= 10) intensity = 3;
            else intensity = 4;
          }
        }

        const cell = document.createElement('div');
        cell.className = `contribution-cell w-[11px] h-[11px] md:w-3 md:h-3 rounded-[2px] ${colors[intensity]} transition-colors duration-300`;

        const d = cellDate.getDate();
        const suffix =
          d % 10 === 1 && d !== 11
            ? 'st'
            : d % 10 === 2 && d !== 12
              ? 'nd'
              : d % 10 === 3 && d !== 13
                ? 'rd'
                : 'th';
        const formattedDate = `${monthNames[cellDate.getMonth()]} ${d}${suffix}`;

        cell.setAttribute('data-tooltip', `${count} contributions on ${formattedDate}`);
        colDiv.appendChild(cell);
      }
      graphContainer.appendChild(colDiv);
    }

    labelsContainer.className = 'flex gap-0.75';
    for (let i = 0; i < cols; i++) {
      const span = document.createElement('span');
      span.className =
        'w-[11px] md:w-3 shrink-0 text-xs font-medium text-muted-foreground overflow-visible whitespace-nowrap';
      const monthLabel = monthLabels.find(l => l.index === i);
      if (monthLabel) span.textContent = monthLabel.name;
      labelsContainer.appendChild(span);
    }

    let tooltip = document.getElementById('gh-tooltip');
    if (!tooltip) {
      tooltip = document.createElement('div');
      tooltip.id = 'gh-tooltip';
      tooltip.className =
        'pointer-events-none fixed z-[100] whitespace-nowrap rounded-lg bg-primary px-3 py-1.5 text-xs font-medium text-primary-foreground opacity-0 shadow-md transition-opacity duration-200 flex flex-col items-center justify-center';

      const arrow = document.createElement('div');
      arrow.className =
        'absolute top-full left-1/2 -translate-x-1/2 h-0 w-0 border-4 border-transparent border-t-primary';
      tooltip.appendChild(arrow);

      const content = document.createElement('span');
      content.id = 'gh-tooltip-content';
      tooltip.appendChild(content);

      document.body.appendChild(tooltip);
    }

    const cells = graphContainer.querySelectorAll('.contribution-cell');
    cells.forEach(cell => {
      cell.addEventListener('mouseenter', _e => {
        const text = cell.getAttribute('data-tooltip');
        if (!text || !tooltip) return;

        const contentEl = document.getElementById('gh-tooltip-content');
        if (contentEl) contentEl.textContent = text;

        tooltip.style.opacity = '1';

        const rect = cell.getBoundingClientRect();
        const tooltipRect = tooltip.getBoundingClientRect();
        tooltip.style.left = `${rect.left + rect.width / 2 - tooltipRect.width / 2}px`;
        tooltip.style.top = `${rect.top - tooltipRect.height - 8}px`;
      });

      cell.addEventListener('mouseleave', () => {
        tooltip.style.opacity = '0';
      });
    });
  }

  renderGraph();

  document.addEventListener('astro:after-swap', () => {
    renderGraph();
  });
</script>
