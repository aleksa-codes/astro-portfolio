<footer
  class="flex cursor-default flex-col items-center justify-center gap-21.5 xs:gap-23.5 md:gap-24.5"
>
  <svg
    aria-hidden="true"
    class="w-90 font-signature text-7xl text-muted-foreground xs:w-100 sm:w-105 md:w-110"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 440 72"
  >
    <text x="220" y="64" text-anchor="middle" fill="currentColor">
      aleksa.codes
    </text>
  </svg>
  <p class="text-sm leading-6 font-medium text-muted-foreground">
    © <span id="current-year">2026</span> · Have a great <span id="current-day"
      >Friday</span
    >
  </p>
</footer>

<script>
  const yearEl = document.getElementById("current-year")
  const dayEl = document.getElementById("current-day")
  if (yearEl) yearEl.textContent = new Date().getFullYear().toString()
  if (dayEl)
    dayEl.textContent = new Date().toLocaleDateString("en-US", {
      weekday: "long",
    })
</script>
