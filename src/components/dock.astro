---
import { cn } from "@/lib/utils"
import { Icon } from "astro-icon/components"

const { pathname } = Astro.url

const navItems = [
  { href: "/", label: "Home", icon: "lucide:home" },
  { href: "/projects", label: "Projects", icon: "lucide:code" },
  { href: "/blog", label: "Blog", icon: "lucide:pen-line" },
  { href: "/contact", label: "Contact", icon: "lucide:mail" },
]

const boxBase =
  "xs:h-12 xs:w-12 xs:rounded-2xl flex h-11 w-11 items-center justify-center rounded-xl border shadow-sm transition-all duration-500 ease-[cubic-bezier(0.34,1.3,0.64,1)] group-hover:-translate-y-1 group-hover:scale-[1.2] md:h-13 md:w-13"
---

<div
  class="pointer-events-none fixed inset-x-0 bottom-6 z-50 flex justify-center px-4"
>
  <nav
    class="pointer-events-auto flex w-fit items-end gap-2 rounded-2xl border border-border bg-background/80 px-3 py-2.5 shadow-2xl backdrop-blur-xl xs:gap-3 xs:rounded-3xl xs:px-4 xs:py-3 sm:gap-3.5"
  >
    {
      navItems.map(({ href, label, icon }) => {
        const active =
          href === "/" ? pathname === "/" : pathname.startsWith(href)
        return (
          <a
            href={href}
            class="group flex shrink-0 flex-col items-center gap-1.5"
          >
            <div
              class={cn(
                boxBase,
                "group-hover:shadow-md",
                active
                  ? "border-primary/25 bg-primary/10 text-primary"
                  : "border-border bg-secondary/50 text-foreground"
              )}
            >
              <Icon name={icon} class="h-5 w-5 xs:h-6 xs:w-6" />
            </div>
            <span
              class={cn(
                "text-sm leading-none font-medium transition-colors duration-300",
                active ? "text-primary" : "text-muted-foreground"
              )}
            >
              {label}
            </span>
          </a>
        )
      })
    }

    <div class="mx-1 w-px shrink-0 self-stretch rounded-full bg-border"></div>

    <button
      id="dock-chat-btn"
      class="group flex shrink-0 cursor-pointer flex-col items-center gap-1.5"
    >
      <div
        class={cn(
          boxBase,
          "border-transparent bg-primary text-primary-foreground shadow-lg group-hover:shadow-xl"
        )}
      >
        <Icon name="lucide:bot-message-square" class="h-5 w-5 xs:h-6 xs:w-6" />
      </div>
      <span class="text-sm leading-none font-medium text-muted-foreground"
        >Ask AI</span
      >
    </button>
  </nav>
</div>

<script>
  document.getElementById("dock-chat-btn")?.addEventListener("click", () => {
    ;(window as any).toggleChat?.()
  })
</script>
